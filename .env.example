# GitHub Authentication
# Option 1: Personal Access Token (PAT) - recommended for development
GITHUB_TOKEN=your_github_pat_here

# Option 2: GitHub App Authentication (recommended for production)
# GITHUB_APP_ID=your_app_id
# GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
# GITHUB_APP_INSTALLATION_ID=your_installation_id

# Server Configuration
PORT=3000
NODE_ENV=development

# Rate limiting & concurrency
GITHUB_CONCURRENCY_LIMIT=10   # max parallel GitHub API calls
CACHE_TTL_SECONDS=300          # cache report for 5 minutes

# Logging
LOG_LEVEL=info
